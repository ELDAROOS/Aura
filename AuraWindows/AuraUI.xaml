<Window x:Class="Aura.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
        Title="Aura" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="-1"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- Background with Mesh Gradient Look -->
        <Border CornerRadius="12" BorderThickness="1" BorderBrush="#33FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A1A2E" Offset="0"/>
                    <GradientStop Color="#FF16213E" Offset="0.5"/>
                    <GradientStop Color="#FF0F3460" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#1AFFFFFF" CornerRadius="12,0,0,12" Margin="0,0,1,0">
                <StackPanel Margin="20,50,20,20">
                    <TextBlock Text="AURA" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>
                    
                    <Button Content="Library" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalAlignment="Left" FontSize="16" Margin="0,10"/>
                    <Button Content="Explore" Background="Transparent" Foreground="#B0B0B0" BorderThickness="0" HorizontalAlignment="Left" FontSize="16" Margin="0,10"/>
                    <Button Content="Search" Background="Transparent" Foreground="#B0B0B0" BorderThickness="0" HorizontalAlignment="Left" FontSize="16" Margin="0,10"/>
                    
                    <TextBlock Text="PLAYLISTS" FontSize="12" FontWeight="Bold" Foreground="#60FFFFFF" Margin="0,30,0,10"/>
                    <Button Content="Favorites" Background="Transparent" Foreground="#B0B0B0" BorderThickness="0" HorizontalAlignment="Left" FontSize="14" Margin="0,5"/>
                    <Button Content="Recently Added" Background="Transparent" Foreground="#B0B0B0" BorderThickness="0" HorizontalAlignment="Left" FontSize="14" Margin="0,5"/>
                </StackPanel>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Border Grid.Row="0" Margin="20,10" Background="#26FFFFFF" CornerRadius="8">
                    <Grid>
                        <TextBlock Text="Search tracks, artists, albums..." Foreground="#80FFFFFF" VerticalAlignment="Center" Margin="15,0"/>
                        <TextBox Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Margin="15,0"/>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Recently Played" FontSize="22" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,20"/>
                        
                        <WrapPanel>
                            <!-- Album Card Mockups -->
                            <StackPanel Margin="0,0,20,20">
                                <Border Width="160" Height="160" Background="#33FFFFFF" CornerRadius="10">
                                    <TextBlock Text="🎵" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="After Hours" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Text="The Weeknd" Foreground="#80FFFFFF" FontSize="12"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,20,20">
                                <Border Width="160" Height="160" Background="#33FFFFFF" CornerRadius="10">
                                    <TextBlock Text="🎸" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Dark Side of the Moon" Foreground="White" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <TextBlock Text="Pink Floyd" Foreground="#80FFFFFF" FontSize="12"/>
                            </StackPanel>
                            
                            <!-- More cards... -->
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Player Bar -->
                <Border Grid.Row="2" Background="#26FFFFFF" CornerRadius="0,0,12,0" Margin="10,0,10,10">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Track Info -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Width="50" Height="50" Background="#33FFFFFF" CornerRadius="4"/>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Blinding Lights" Foreground="White" FontWeight="Bold"/>
                                <TextBlock Text="The Weeknd" Foreground="#80FFFFFF" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Controls -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="⏮" FontSize="20" Background="Transparent" BorderThickness="0" Foreground="White" Margin="10,0"/>
                                <Button Content="▶" FontSize="30" Background="Transparent" BorderThickness="0" Foreground="White" Margin="10,0"/>
                                <Button Content="⏭" FontSize="20" Background="Transparent" BorderThickness="0" Foreground="White" Margin="10,0"/>
                            </StackPanel>
                            <Slider Margin="0,10,0,0" Maximum="100" Value="45"/>
                        </StackPanel>

                        <!-- Volume -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="🔊" Foreground="White" Margin="0,0,10,0"/>
                            <Slider Width="100" Maximum="100" Value="80"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
