<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aura" Height="850" Width="1250" WindowStartupLocation="CenterScreen"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None">
    
    <Window.Resources>
        <Style x:Key="SidebarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#10FFFFFF"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border CornerRadius="18" BorderThickness="1" BorderBrush="#22FFFFFF" ClipToBounds="True">
            <Grid>
                <!-- Mesh Background -->
                <Rectangle Fill="#FF0A0A0A"/>
                <Ellipse Fill="#22FA233B" Width="800" Height="800" Margin="-400,-400,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect>
                </Ellipse>
                <Ellipse Fill="#228E2DE2" Width="700" Height="700" Margin="0,0,-300,-300" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect>
                </Ellipse>

                <!-- MAIN LAYOUT -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- SIDEBAR -->
                    <Border Grid.Column="0" Background="#15000000" BorderBrush="#1AFFFFFF" BorderThickness="0,0,1,0">
                        <Grid>
                            <StackPanel Margin="25,70,25,25">
                                <TextBlock Text="Aura" FontSize="34" FontWeight="Bold" Foreground="White" Margin="10,0,0,45"/>
                                <TextBlock Text="Discovery" FontSize="11" FontWeight="Bold" Foreground="#66FFFFFF" Margin="15,0,0,12"/>
                                <Button x:Name="BtnHome" Style="{StaticResource SidebarBtn}" Content="🏠  Listen Now"/>
                                <Button x:Name="BtnRecent" Style="{StaticResource SidebarBtn}" Content="🕒  Recently Added"/>
                                <Button x:Name="BtnFavorites" Style="{StaticResource SidebarBtn}" Content="⭐  Top Charts"/>
                                <Button x:Name="BtnImport" Style="{StaticResource SidebarBtn}" Content="🔗  Import Link" Foreground="#FFFA233B"/>
                                <TextBlock Text="Library" FontSize="11" FontWeight="Bold" Foreground="#66FFFFFF" Margin="15,35,0,12"/>
                                <Button x:Name="BtnSongs" Style="{StaticResource SidebarBtn}" Content="🎵  Songs"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="90"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="125"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="40,0">
                            <Border Background="#1AFFFFFF" CornerRadius="10" Height="42" Width="400" HorizontalAlignment="Right" Margin="0,0,60,0">
                                <Grid>
                                    <TextBlock Text="Search music..." Foreground="#44FFFFFF" VerticalAlignment="Center" Margin="15,0"/>
                                    <TextBox x:Name="TxtSearch" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Margin="15,0" FontSize="15"/>
                                </Grid>
                            </Border>
                            <Button x:Name="BtnClose" Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,-10,0" Background="Transparent" Foreground="#33FFFFFF" BorderThickness="0" FontSize="20"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="40,0">
                            <StackPanel>
                                <TextBlock x:Name="LblTitle" Text="Listen Now" FontSize="38" FontWeight="Bold" Foreground="White" Margin="0,0,0,35"/>
                                <Border Height="220" CornerRadius="15" Margin="0,0,0,40">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFFA233B" Offset="0"/><GradientStop Color="#FF8E2DE2" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid Margin="40">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="FEATURED" Foreground="#80FFFFFF" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="New Releases" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,5"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <WrapPanel x:Name="AlbumGrid"></WrapPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- PLAYER -->
                        <Border Grid.Row="2" Background="#15000000" BorderThickness="0,1,0,0" BorderBrush="#1AFFFFFF">
                            <Grid Margin="35,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="380"/><ColumnDefinition Width="*"/><ColumnDefinition Width="380"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="75" Height="75" Background="#26FFFFFF" CornerRadius="12"><TextBlock Text="🎵" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <StackPanel Margin="20,0,0,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtNowPlaying" Text="Aura Player" Foreground="White" FontWeight="Bold" FontSize="18"/>
                                        <TextBlock x:Name="TxtArtist" Text="Select music" Foreground="#80FFFFFF" FontSize="14"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button x:Name="BtnPlayPause" Content="▶" FontSize="45" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
